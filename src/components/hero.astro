---
import { Image } from 'astro:assets';
---

<!-- SECTION 1 — HERO -->
<section class="relative min-h-screen flex items-center pt-20 overflow-hidden bg-primary">
<div class="absolute inset-0 opacity-30 pointer-events-none">
<img alt="" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCi2srp8Bjfr-8JnRKOa1YW3vkDmbZX2Au6PIwZIhwdP9xIu57vWjQD83aGjIV5vDhNctfQrxUkfgAjsAMBOaAXYtKMWtn1EC5bgj_3P9T9xITNqIdlw4hzZGHdEgvvFxAu4CZXh2GxNYk_AmRJ5v8QrAd5NW7omnSypX_mbcsRXhnHhGUEfmBnOP26xxFo_W9rGlXCKTTdbzqeDkIaAShc_oGQRyM7ASdHRaeRYDC4kMG5KVeiB1F6BedWFtEl6CY6bFNHue4BPuVr"/>
<div class="absolute inset-0 bg-gradient-to-r from-primary via-primary/80 to-transparent"></div>
</div>
<div class="relative max-w-7xl mx-auto px-6 w-full py-20">
<div class="max-w-3xl">
<h1 class="text-surface-container-lowest font-headline text-5xl md:text-8xl leading-[1] tracking-tighter mb-8">
                    Where Trucks Meet Their Match
                </h1>
<p class="text-primary-fixed text-2xl md:text-3xl font-medium mb-4 leading-tight">
                    Zambia's specialist truck brokerage — connecting companies that need trucks with owners who have them.
                </p>
<p class="text-secondary-fixed-dim text-lg md:text-xl font-bold mb-12 uppercase tracking-wide">
                    Professional. Vetted. Managed from match to close.
                </p>
<div class="flex flex-wrap gap-4">
<button class="gold-button text-white px-10 py-5 rounded-lg font-bold text-lg hover:brightness-110 transition-all monolith-shadow">
                        I Need Trucks
                    </button>
<button class="border-2 border-primary-fixed/30 text-surface-container-lowest px-10 py-5 rounded-lg font-bold text-lg hover:bg-surface-container-lowest/10 transition-all">
                        I Have Trucks
                    </button>
</div>
</div>
</div>
</section>